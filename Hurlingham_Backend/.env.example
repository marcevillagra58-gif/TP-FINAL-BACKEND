# Variables de entorno — Backend Hurlingham PNO
# ⚠️ NUNCA subir este archivo a GitHub (está en .gitignore)
# Copiar como .env y completar con los valores reales

# ========================
# SERVIDOR
# ========================
PORT=3000
NODE_ENV=development

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ========================
# BASE DE DATOS SQL (Supabase)
# Obtener en: supabase.com → Settings → API
# ========================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...

# ========================
# BASE DE DATOS NoSQL (MongoDB Atlas)
# Obtener en: mongodb.com/atlas → Connect → Drivers
# ========================
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/hurlingham_pno?retryWrites=true&w=majority

# ========================
# AUTENTICACIÓN JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ========================
JWT_SECRET=reemplazar_con_clave_aleatoria_larga_de_64_chars
JWT_REFRESH_SECRET=reemplazar_con_otra_clave_diferente_aleatoria

# ========================
# IMÁGENES (Cloudinary)
# Obtener en: cloudinary.com → Dashboard
# ========================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
